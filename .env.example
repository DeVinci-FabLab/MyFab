# =============================================================================
# Copy this file to .env and fill in the values for your instance.
# Vars are grouped: REQUIRED (must be set) and OPTIONAL (feature-gated).
# =============================================================================

# =============================================================================
# REQUIRED — the stack will not work without these
# =============================================================================

# ---- Instance identity --------------------------------------------------------
# Suffix appended to container names — lets multiple instances coexist on one host.
# E.g. SLUG=test gives containers myfab-db-test, myfab-back-test, myfab-front-test.
# Use lowercase + dashes only (Docker name rules).
SLUG=prod
# Docker compose project name — isolates volumes, networks, etc. per instance.
# Recommended to set in lockstep with SLUG so two instances don't share state.
COMPOSE_PROJECT_NAME=myfab-${SLUG}
# Base directory on the host for bind-mounted persistent data (DB, uploads, logs).
VOLUMES_PATH=/srv/docker

# ---- Database -----------------------------------------------------------------
# DB host as seen from the back container. Use the mariadb service/container name.
DB_HOST=mariadb
DB_USER=myfab
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root
DB_DATABASE=myfab

# ---- Backend core -------------------------------------------------------------
# Public API URL. Read by back and injected into front's window.__ENV__ at SSR.
API=https://myfab.example.com
# Session/JWT secret. Generate a long random string. Empty = insecure sessions.
SPECIALTOKEN=replace-with-long-random-string

# =============================================================================
# OPTIONAL — only needed if you use the corresponding feature
# =============================================================================

# ---- Mail / notifications (required if your users send tickets, register,
#      reset passwords, or receive any email) ----------------------------------
# Public front URL — only used inside email templates.
FRONT_URL=https://myfab.example.com
MAIL_HOST=smtp.example.com
MAIL_USER=noreply@example.com
MAIL_PASSWORD=change-me

# ---- Swagger / API docs -------------------------------------------------------
# Set to "true" to expose /api-docs Swagger UI. Defaults to off if unset.
SHOWSWAGGER=false

# ---- SAML / ADFS (DEPRECATED — left for reference) ---------------------------
# The SAML passport strategy is only registered if back/data/cert exists.
# If you don't have that file, these vars are ignored. Safe to omit entirely.
# ADSF_ENTRYPOINT=https://idp.example.com/adfs/ls
# ADSF_ISSUER=https://myfab.example.com
# ADFS_FRONT_URL=https://myfab.example.com/auth/adfs/

# ---- Frontend build-time (already defaults in next.config.js) ----------------
# These have safe defaults ("", "false", "false") baked into next.config.js.
# Override here ONLY if you need non-default behavior, AND set the matching
# GitHub repo variables for CI builds, otherwise SSR and the client bundle
# will disagree.
# BASE_PATH=
# IS_TEST_MODE=false
# DARK_MODE_IN_TEST_MODE=false
